    <update id="updateProfile">
        UPDATE Profile
        SET
            url_avatar = #{profileRequest.urlAvatar},
            bio = #{profileRequest.bio},
            full_name = #{profileRequest.fullName},
            birth_date = #{profileRequest.birthDate}
        WHERE account_id = #{accountId}
    </update>

</mapper>