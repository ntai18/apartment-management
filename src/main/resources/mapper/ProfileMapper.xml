<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.apartmentmanagement.features.profile.mapper.ProfileMapper">
    <insert id="createProfile">
        INSERT INTO Profile(account_id, url_avatar, full_name, birth_date, bio)
        VALUES (#{accountId}, #{profileRequest.urlAvatar}, #{profileRequest.fullName}, #{profileRequest.birthDate}, #{profileRequest.bio})
    </insert>

    <select id="isValidation">
        SELECT account_id FROM Profile
        WHERE account_id = #{accountId}
    </select>

    <select id="getProfile">
        SELECT * FROM Profile
        WHERE account_id = #{accountId}
    </select>

